            <general><enabled>0</enabled></general>
            <product><enabled>1</enabled><variants_enabled>1</variants_enabled></product>
            <category><enabled>1</enabled></category>
            <opengraph><enabled>1</enabled></opengraph>
            <cms><enabled>1</enabled></cms>
        </etechflow_richsnippets>
    </default>
</config>
